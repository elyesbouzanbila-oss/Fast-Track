# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL + PostGIS ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=navdb
DB_USER=navuser
DB_PASSWORD=navpassword

# ── OSRM Routing ─────────────────────────────────────────────────────────
# Dockerized OSRM is the default path. Start the OSRM services via docker compose.
OSRM_CAR_URL=http://nav_osrm_car:5000
OSRM_FOOT_URL=http://nav_osrm_foot:5000

# Set to 'true' only if you want to skip OSRM and return estimated (demo) routes.
SKIP_OSRM=false

# ── JWT Auth ──────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production.
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── Geocoding (Nominatim / OpenStreetMap) ─────────────────────────────────
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ──────────────────────────────────────────────────────────────────
# Lock this down to your frontend domain in production.
CORS_ORIGIN=*

# ── GTFS Transit Data ─────────────────────────────────────────────────────
GTFS_DATA_PATH=./data/gtfs
